{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "Mohandseto Tawredat Design Tokens",
    "source": "Mohandseto_Tawredat_Final design.pdf (759 pages)",
    "extraction": "Vector fills from intro pages + pixel sampling of screen bitmaps",
    "version": "0.1.0"
  },
  "color": {
    "brand": {
      "primary": "#023BAA",
      "primaryDark": "#012E86",
      "primaryLight": "#2F62C9",
      "primaryTint": "#EFF3FC",
      "splashNavy": "#10255C",
      "onPrimary": "#FFFFFF"
    },
    "admin": {
      "sidebar": "#103B5C",
      "sidebarActive": "#1C4E74",
      "sidebarText": "#D7E3EC",
      "teal": "#167A8B",
      "tealTint": "#EAF4F5",
      "accentOrange": "#F59E42",
      "background": "#F6F9FB"
    },
    "neutral": {
      "0": "#FFFFFF",
      "25": "#FBFCFE",
      "50": "#F7F9FC",
      "100": "#F3F6F9",
      "150": "#F0F2F5",
      "200": "#E4E7EC",
      "300": "#D0D5DD",
      "400": "#98A2B3",
      "500": "#667085",
      "600": "#475467",
      "700": "#344054",
      "800": "#1D2939",
      "900": "#101828"
    },
    "semantic": {
      "success": "#067647",
      "successTint": "#ECFDF3",
      "warning": "#F79009",
      "warningTint": "#FFF4E8",
      "warningDeep": "#B93815",
      "error": "#D92D20",
      "errorTint": "#FEF3F2",
      "info": "#175CD3",
      "infoTint": "#EFF8FF"
    },
    "clientApp": {
      "background": "#F8F9FB",
      "card": "#FFFFFF",
      "bottomNavActive": "#023BAA",
      "bottomNavInactive": "#98A2B3"
    }
  },
  "typography": {
    "fontFamilyArabic": "Cairo",
    "fontFamilyLatin": "Cairo",
    "note": "PDF embeds Type3 subsets without names; Cairo chosen as closest geometric rounded Arabic sans (documented in docs/assumptions.md)",
    "scale": {
      "display": { "size": 28, "weight": 700, "lineHeight": 1.35 },
      "h1": { "size": 22, "weight": 700, "lineHeight": 1.4 },
      "h2": { "size": 18, "weight": 700, "lineHeight": 1.4 },
      "h3": { "size": 16, "weight": 600, "lineHeight": 1.45 },
      "bodyLarge": { "size": 15, "weight": 500, "lineHeight": 1.6 },
      "body": { "size": 13, "weight": 400, "lineHeight": 1.6 },
      "caption": { "size": 11, "weight": 400, "lineHeight": 1.5 },
      "micro": { "size": 9, "weight": 400, "lineHeight": 1.4 }
    }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 12, "lg": 16, "xl": 20, "2xl": 24, "3xl": 32, "4xl": 40 },
  "radius": { "sm": 8, "md": 12, "lg": 16, "xl": 20, "pill": 999, "phoneFrame": 44 },
  "shadow": {
    "card": "0 1px 3px rgba(16,24,40,0.06), 0 1px 2px rgba(16,24,40,0.04)",
    "elevated": "0 12px 24px -6px rgba(16,24,40,0.12)",
    "sidebar": "0 0 0 1px rgba(16,59,92,0.04)"
  },
  "breakpoints": { "phone": 390, "tablet": 768, "desktop": 1440 },
  "motion": {
    "fast": "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "normal": "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "400ms cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
