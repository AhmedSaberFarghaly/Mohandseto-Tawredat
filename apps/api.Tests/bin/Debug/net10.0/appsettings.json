{
  "ConnectionStrings": {
    "Default": "Data Source=mohandseto.db"
  },
  "Jwt": {
    "Issuer": "mohandseto-api",
    "Audience": "mohandseto-clients",
    "Key": "DEV-ONLY-KEY-change-via-environment-variable-Jwt__Key-0123456789",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30
  },
  "Cors": {
    "Origins": [ "http://localhost:3000", "http://localhost:8080" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
