# === API (ASP.NET Core) — pass as environment variables in production ===
# Strong random key (>= 48 chars). NEVER use the development placeholder in production.
Jwt__Key=
ConnectionStrings__Default=Data Source=mohandseto.db
# Production example (SQL Server):
# ConnectionStrings__Default=Server=...;Database=Mohandseto;User Id=...;Password=...;TrustServerCertificate=True

# === Admin Web (Next.js) ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:5199

# === Client (Flutter) — passed via --dart-define ===
# API_BASE_URL=http://localhost:5199

# === External integrations (adapters work without them in dev) ===
SMS_PROVIDER_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
WHATSAPP_BUSINESS_TOKEN=
FIREBASE_SERVER_KEY=
MAPS_API_KEY=
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
