# === API (ASP.NET Core) — pass as environment variables in production ===
# Strong random key (>= 48 chars). NEVER use the development placeholder in production.
Jwt__Key=
ConnectionStrings__Default=Data Source=mohandseto.db
AllowedHosts=api.example.com
Cors__Origins__0=https://admin.example.com
DataProtection__KeysPath=/var/lib/mohandseto/keys
ForwardedHeaders__KnownProxies__0=172.31.50.1
Database__MigrateOnStartup=false
Seed__Enabled=false
# Current release uses a persistent SQLite volume in single-instance mode.
# SQL Server migration is a separate provider cutover and must not reuse the SQLite migration set.

# === Admin Web (Next.js) ===
API_BASE_URL=http://localhost:5199
DEPLOYMENT_VERSION=local
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# === Client (Flutter) — passed via --dart-define ===
# API_BASE_URL=http://localhost:5199

# === External integrations (adapters work without them in dev) ===
SMS_PROVIDER_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
WHATSAPP_BUSINESS_TOKEN=
FIREBASE_SERVER_KEY=
MAPS_API_KEY=
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=
Payments__Provider=
Payments__BankName=
Payments__BankAccountName=
Payments__BankIban=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
